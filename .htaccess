<IfModule LiteSpeed>
    RewriteEngine On
    RewriteRule .* - [E=cache-control:no-cache]
    CacheDisable public /
</IfModule>

<IfModule mod_headers.c>
    Header always set Cache-Control "no-cache, no-store, must-revalidate"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
</IfModule>
